# ─────────────────────────────────────────────────────────────────────────
# EntraSave API (Express) — environment template. Copy to `.env` and fill in
# REAL values. `.env` is git-ignored. Validated at boot by src/config/env.ts
# (Zod) — the server REFUSES TO START if anything here is invalid.
# ─────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# Express API.
PORT=4000
# Public base URL of THIS API (used to derive OAuth callback URLs).
APP_URL=http://localhost:4000
# Origin of the React client (CORS allowlist + post-OAuth redirect target).
CLIENT_URL=http://localhost:5173

# SQL Server 2017, database "Finance" (same schema as the Next.js app).
# Format: sqlserver://HOST:1433;database=Finance;user=USER;password=PASS;encrypt=true;trustServerCertificate=true
DATABASE_URL="sqlserver://localhost:1433;database=Finance;user=finance_app;password=CHANGE_ME;encrypt=true;trustServerCertificate=true"

# Self-managed authentication. Generate JWT_SECRET with a cryptographic RNG
# (at least 32 random bytes; do not reuse an OAuth or database secret).
JWT_SECRET=CHANGE_ME_TO_AT_LEAST_32_RANDOM_BYTES
JWT_ISSUER=entrasave
JWT_AUDIENCE=entrasave-web
SESSION_TTL_SECONDS=28800

# Google OAuth web application credentials.
# Callback: http://localhost:4000/api/auth/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Meta/Facebook Login credentials. Keep the Graph version explicit so provider
# upgrades are reviewed instead of changing silently.
# Callback: http://localhost:4000/api/auth/oauth/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_GRAPH_VERSION=

# Logging
LOG_LEVEL=info

# ── Future / optional (leave blank until needed) ──────────────────────────
# REDIS_URL=redis://localhost:6379
# STORAGE_DRIVER=local
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# TURNSTILE_SECRET=
